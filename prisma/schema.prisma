generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                  @id @default(uuid())
  email                String                  @unique
  senha                String
  tinyToken            String?
  cepOrigem            String?                 @default("01001000")
  createdAt            DateTime                @default(now())
  passwordResetToken   String?
  passwordResetExpires DateTime?
    // Integrações de imagem
  imgurClientId        String?
  imgurClientSecret    String?
  removeBgApiKey       String?
  configAtacado        ConfigAtacado?
  contasMl             ContaML[]
  perfisCompat         PerfilCompatibilidade[]
  produtos             Produto[]
  regrasOrquestrador   RegraOrquestrador[]
  regras               RegraPreco[]
  tarefas              TarefaFila[]
  verificacaoPreco     VerificacaoPreco?
}

model ConfigAtacado {
  id     String  @id @default(uuid())
  userId String  @unique
  ativo  Boolean @default(false)
  faixas Json
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificacaoPreco {
  id         String   @id @default(uuid())
  userId     String   @unique
  resultados Json
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContaML {
  id           String       @id @default(uuid())
  userId       String
  nickname     String
  accessToken  String
  refreshToken String
  expiresAt    BigInt
  logistica    String       @default("ME2")
  anuncios     AnuncioML[]
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  perguntas    PerguntaML[]
  promocoes    PromoML[]
}

model AnuncioML {
  id                String   @id
  contaId           String
  sku               String?
  titulo            String
  preco             Float
  precoOriginal     Float?
  status            String
  estoque           Int
  vendas            Int      @default(0)
  visitas           Int      @default(0)
  thumbnail         String?
  permalink         String?
  dadosML           Json?
  updatedAt         DateTime @updatedAt
  tagPrincipal      String?
  margemPromocional Boolean  @default(false)
  conta             ContaML  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
  @@index([tagPrincipal])
}

model RegraPreco {
  id        String @id @default(uuid())
  userId    String
  nome      String
  variaveis Json
  precoBase String @default("promocional")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Produto {
  id        String   @id @default(uuid())
  userId    String
  sku       String
  nome      String
  preco     Float
  estoque   Int
  statusML  String   @default("Não Publicado")
  dadosTiny Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sku])
  @@index([userId])
}

model PerfilCompatibilidade {
  id                   String   @id @default(uuid())
  userId               String
  nome                 String
  descricao            String?
  compatibilidadesJson String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
  @@index([userId])
}

model TarefaFila {
  id         String   @id @default(uuid())
  userId     String
  jobId      String?
  tipo       String
  alvo       String?
  conta      String?
  status     String   @default("PENDENTE")
  tentativas Int      @default(0)
  detalhes   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerguntaML {
  id            String    @id
  contaId       String
  itemId        String
  compradorId   String?
  textoPergunta String
  textoResposta String?
  status        String
  dataCriacao   DateTime
  dataResposta  DateTime?
  dadosML       Json?
  conta         ContaML   @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId, status])
  @@index([itemId])
}

model PromoML {
  id            String
  contaId       String
  tipo          String
  sub_type      String?
  status        String
  nome          String?
  startDate     DateTime?
  finishDate    DateTime?
  deadline_date DateTime?
  itens         Json?
  benefits      Json?
  dadosML       Json?
  fetchedAt     DateTime  @default(now())
  conta         ContaML   @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@id([id, contaId])
  @@index([contaId])
  @@index([tipo])
  @@index([status])
}

model RegraOrquestrador {
  id              String   @id @default(uuid())
  userId          String
  nome            String
  tiposPermitidos String[]
  maxSellerPct    Float
  tolerancia      Float    @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

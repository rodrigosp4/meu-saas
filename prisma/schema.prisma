generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  OPERATOR
  VIEWER
  SUPPORT
}

model User {
  id                   String                  @id @default(uuid())
  email                String                  @unique
  senha                String
  tinyClientId         String?
  tinyClientSecret     String?
  tinyAccessToken      String?
  tinyRefreshToken     String?
  tinyTokenExpiresAt   BigInt?
  tinyPlano            String?                 @default("descontinuado")
  cepOrigem            String?                 @default("01001000")
  createdAt            DateTime                @default(now())
  passwordResetToken   String?
  passwordResetExpires DateTime?
  // Controle de usuários
  role                 UserRole                @default(OWNER)
  ativo                Boolean                 @default(true)
  parentUserId         String?
  parentUser           User?                   @relation("SubUsuarios", fields: [parentUserId], references: [id])
  subUsuarios          User[]                  @relation("SubUsuarios")
  permissoesCustom     Json?
  featureFlags         Json?                   // { "monitorConcorrentes": false } → oculta módulo
  // Acesso de suporte
  suporteAtivo         Boolean                 @default(false)
  suporteExpira        DateTime?
  sessoesSuporteDadas      SessaoSuporte[]     @relation("SessoesDadas")
  sessoesSuporteRecebidas  SessaoSuporte[]     @relation("SessoesRecebidas")
  // Integrações de imagem
  imgurClientId        String?
  imgurClientSecret    String?
  removeBgApiKey       String?
  configAtacado        ConfigAtacado?
  contasMl             ContaML[]
  perfisCompat         PerfilCompatibilidade[]
  produtos             Produto[]
  regrasOrquestrador   RegraOrquestrador[]
  monitorPromoConfig   MonitorPromoConfig?
  promoAlertas         PromoAlerta[]
  regras               RegraPreco[]
  tarefas              TarefaFila[]
  verificacaoPreco     VerificacaoPreco?
  gruposMonitoramento  GrupoMonitoramento[]
  lojasMonitoradas     LojaMonitorada[]
  resourceFlags        Json?                   // { "catalogo.criar": false } → bloqueia recurso granular
  // Assinatura
  acessoLivre          Boolean                 @default(false)
  assinaturas          Assinatura[]
  notificacaoCache     NotificacaoCache?
}

model Assinatura {
  id              String    @id @default(uuid())
  userId          String
  plano           String    // "30d", "60d", "90d", "180d"
  valor           Float
  status          String    // "pending", "approved", "cancelled", "expired"
  mpPaymentId     String?
  mpPreferenceId  String?
  iniciaEm        DateTime?
  expiraEm        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiraEm])
}

model ConfigAssinatura {
  id             String   @id @default("global")
  precoMensal    Float    @default(299.00)
  mpAccessToken  String?
  mpPublicKey    String?
  updatedAt      DateTime @updatedAt
}

model ConfigGlobal {
  id                   String   @id @default("global")
  defaultFeatureFlags  Json?    // flags de módulo aplicadas a novos cadastros OWNER
  defaultResourceFlags Json?    // flags de recurso aplicadas a novos cadastros OWNER
  updatedAt            DateTime @updatedAt
}

model SessaoSuporte {
  id            String   @id @default(uuid())
  suporteUserId String
  targetUserId  String
  criadaEm      DateTime @default(now())
  expiraEm      DateTime
  ativa         Boolean  @default(true)
  suporteUser   User     @relation("SessoesDadas", fields: [suporteUserId], references: [id])
  targetUser    User     @relation("SessoesRecebidas", fields: [targetUserId], references: [id])

  @@index([suporteUserId])
  @@index([targetUserId])
}

model ConfigAtacado {
  id     String  @id @default(uuid())
  userId String  @unique
  ativo  Boolean @default(false)
  faixas Json
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificacaoPreco {
  id         String   @id @default(uuid())
  userId     String   @unique
  resultados Json
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContaML {
  id           String       @id @default(uuid())
  userId       String
  nickname     String
  accessToken  String
  refreshToken String
  expiresAt    BigInt
  logistica    String       @default("ME2")
  regraPrecoId String?
  anuncios     AnuncioML[]
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  perguntas    PerguntaML[]
  promocoes    PromoML[]
  regraPreco   RegraPreco?  @relation(fields: [regraPrecoId], references: [id], onDelete: SetNull)
}

model AnuncioML {
  id                String   @id
  contaId           String
  sku               String?
  titulo            String
  preco             Float
  precoOriginal     Float?
  status            String
  estoque           Int
  vendas            Int      @default(0)
  visitas           Int      @default(0)
  thumbnail         String?
  permalink         String?
  dadosML           Json?
  skusVariacoes     String[] @default([])
  updatedAt         DateTime @updatedAt
  tagPrincipal      String?
  margemPromocional Boolean  @default(false)
  inflarPct         Float    @default(0)
  conta             ContaML  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
  @@index([tagPrincipal])
}

model RegraPreco {
  id                String    @id @default(uuid())
  userId            String
  nome              String
  variaveis         Json
  precoBase         String    @default("promocional")
  variacoesPorConta Json?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contasMl          ContaML[]
}

model Produto {
  id        String   @id @default(uuid())
  userId    String
  sku       String
  nome      String
  preco     Float
  estoque   Int
  statusML      String   @default("Não Publicado")
  dadosTiny     Json?
  imagensCustom Json?
  updatedAt     DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sku])
  @@index([userId])
}

model PerfilCompatibilidade {
  id                   String   @id @default(uuid())
  userId               String
  nome                 String
  descricao            String?
  compatibilidadesJson String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
  @@index([userId])
}

model TarefaFila {
  id         String   @id @default(uuid())
  userId     String
  jobId      String?
  tipo       String
  alvo       String?
  conta      String?
  status     String   @default("PENDENTE")
  tentativas Int      @default(0)
  detalhes   String?
  payload    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerguntaML {
  id            String    @id
  contaId       String
  itemId        String
  compradorId   String?
  textoPergunta String
  textoResposta String?
  status        String
  dataCriacao   DateTime
  dataResposta  DateTime?
  dadosML       Json?
  conta         ContaML   @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId, status])
  @@index([itemId])
}

model PromoML {
  id            String
  contaId       String
  tipo          String
  sub_type      String?
  status        String
  nome          String?
  startDate     DateTime?
  finishDate    DateTime?
  deadline_date DateTime?
  itens         Json?
  benefits      Json?
  dadosML       Json?
  fetchedAt     DateTime  @default(now())
  conta         ContaML   @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@id([id, contaId])
  @@index([contaId])
  @@index([tipo])
  @@index([status])
}

model RegraOrquestrador {
  id              String   @id @default(uuid())
  userId          String
  nome            String
  tiposPermitidos String[]
  maxSellerPct    Float
  tolerancia      Float    @default(0)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Monitor de Concorrentes ───────────────────────────────────────────────────

model GrupoMonitoramento {
  id           String               @id @default(uuid())
  userId       String
  nome         String
  skus         String[]
  precoMinimo  Float?
  autoIgualar  Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  concorrentes ConcorrenteAnuncio[]

  @@unique([userId, nome])
  @@index([userId])
}

model ConcorrenteAnuncio {
  id             String             @id  // MLB item ID
  grupoId        String
  titulo         String
  preco          Float
  estoqueRange   String?
  vendas         Int                @default(0)
  thumbnail      String?
  permalink      String?
  sellerId       String?
  sellerNickname String?
  listingTypeId  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  grupo          GrupoMonitoramento @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  historico      PrecoHistorico[]

  @@index([grupoId])
}

model PrecoHistorico {
  id          String             @id @default(uuid())
  itemId      String
  preco       Float
  capturedAt  DateTime           @default(now())
  concorrente ConcorrenteAnuncio @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([capturedAt])
}

model LojaMonitorada {
  id             String   @id @default(uuid())
  userId         String
  sellerId       String   // ML seller ID (numérico como string)
  nickname       String
  nivel          String?  // platinum, gold, silver, bronze, green
  reputacaoData  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerId])
  @@index([userId])
}

// ── Monitor de Promoções ──────────────────────────────────────────────────────

model MonitorPromoConfig {
  id                   String   @id @default(uuid())
  userId               String   @unique
  ativo                Boolean  @default(true)
  maxSellerPct         Float    @default(20)
  autoAtivar           Boolean  @default(false)
  tiposIgnorar         Json     @default("[]")
  usarDescontoDinamico Boolean  @default(false)
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoAlerta {
  id           String    @id @default(uuid())
  userId       String
  contaId      String
  promoId      String
  tipo         String
  nome         String?
  sellerPct    Float?
  detectadaEm  DateTime  @default(now())
  aceita       Boolean?  // null = pendente, true = aceita, false = ignorada
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promoId])
  @@index([userId, aceita])
}

// ── Cache de Notificações ─────────────────────────────────────────────────────
model NotificacaoCache {
  userId             String   @id
  msgNaoLidas        Int      @default(0)
  perguntasPendentes Int      @default(0)
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

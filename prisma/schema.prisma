generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                  @id @default(uuid())
  email                String                  @unique
  senha                String
  tinyToken            String?
  createdAt            DateTime                @default(now())
  passwordResetToken   String?
  passwordResetExpires DateTime?
  contasMl             ContaML[]
  perfisCompat         PerfilCompatibilidade[]
  produtos             Produto[]
  regras               RegraPreco[]
  tarefas              TarefaFila[]
  verificacaoPreco     VerificacaoPreco?
}

model VerificacaoPreco {
  id         String   @id @default(uuid())
  userId     String   @unique
  resultados Json
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContaML {
  id           String      @id @default(uuid())
  userId       String
  nickname     String
  accessToken  String
  refreshToken String
  expiresAt    BigInt
  logistica    String      @default("ME2")
  anuncios     AnuncioML[]
  perguntas    PerguntaML[] // <-- ADICIONE ESTA LINHA
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnuncioML {
  id            String   @id
  contaId       String
  sku           String?
  titulo        String
  preco         Float
  precoOriginal Float?
  status        String
  estoque       Int
  vendas        Int      @default(0)
  visitas       Int      @default(0)
  thumbnail     String?
  permalink     String?
  dadosML       Json?
  updatedAt     DateTime @updatedAt
  tagPrincipal  String?
  conta         ContaML  @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
  @@index([tagPrincipal])
}

model RegraPreco {
  id        String @id @default(uuid())
  userId    String
  nome      String
  variaveis Json
  precoBase String @default("promocional")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Produto {
  id        String   @id @default(uuid())
  userId    String
  sku       String
  nome      String
  preco     Float
  estoque   Int
  statusML  String   @default("Não Publicado")
  dadosTiny Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sku])
  @@index([userId])
}

model PerfilCompatibilidade {
  id                   String   @id @default(uuid())
  userId               String
  nome                 String
  descricao            String?
  compatibilidadesJson String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
  @@index([userId])
}

model TarefaFila {
  id         String   @id @default(uuid())
  userId     String
  jobId      String?
  tipo       String
  alvo       String?
  conta      String?
  status     String   @default("PENDENTE")
  tentativas Int      @default(0)
  detalhes   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerguntaML {
  id            String    @id // Vamos usar String pois IDs do ML são gigantes
  contaId       String
  itemId        String
  compradorId   String?
  textoPergunta String
  textoResposta String?
  status        String
  dataCriacao   DateTime
  dataResposta  DateTime?
  dadosML       Json?     // Para guardar a resposta crua do ML por segurança

  conta         ContaML   @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId, status])
  @@index([itemId])
}